// 小说目录页密码保护 - 小弹窗，不覆盖全屏
if page.password
  div#novel-lock-screen(style="text-align:center; padding: 50px 20px; background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); border-radius: 12px; margin: 30px auto; max-width: 500px;")
    h2(style="color: #f7f5f0; margin-bottom: 15px;") 🔒 站住！
    p#lock-message(style="color: #8a8580; font-size: 0.95em; margin-bottom: 30px;")= page.encrypt_message || '请输入密码查看'
    div(style="display: flex; justify-content: center; gap: 10px; flex-wrap: wrap;")
      input#lock-input(type="text" placeholder="输入密码..." style="padding: 12px 18px; border: 1px solid #444; border-radius: 8px; background: #2a2a2a; color: #f7f5f0; font-size: 1em; width: 200px;" lang="zh-CN")
      button#lock-btn(style="padding: 12px 24px; background: #c44536; color: #fff; border: none; border-radius: 8px; cursor: pointer; font-size: 1em;") 🔓 进入
    p#lock-error(style="color: #c44536; margin-top: 15px; display: none;")= page.encrypt_wrong || '❌ 密码错误'

  script.
    (function() {
      var password = '!{page.password}';
      var lockScreen = document.getElementById('novel-lock-screen');
      var article = document.getElementById('article-container');
      var btn = document.getElementById('lock-btn');
      var input = document.getElementById('lock-input');
      var error = document.getElementById('lock-error');

      function unlock() {
        if (input.value.trim() === password) {
          lockScreen.style.display = 'none';
          if (article) article.style.display = 'block';
        } else {
          error.style.display = 'block';
          input.value = '';
          input.focus();
        }
      }

      btn.addEventListener('click', unlock);
      input.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') unlock();
      });
      input.focus();
    })();
