// 小说目录页密码保护 - 弹窗固定覆盖视口
if page.password
  div#novel-lock-overlay(style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(26, 26, 26, 0.92); z-index: 9999; display: flex; align-items: center; justify-content: center;")
    div(style="text-align: center; padding: 50px 40px; background: #f7f5f0; border-radius: 16px; max-width: 400px; width: 85%; box-shadow: 0 20px 60px rgba(0,0,0,0.5);")
      div(style="font-size: 2.5em; margin-bottom: 10px;") 🔒
      h2(style="color: #1a1a1a; margin-bottom: 8px; font-size: 1.5em; font-family: 'Noto Serif SC', serif;") 站住！
      p#lock-msg(style="color: #8a8580; font-size: 0.9em; margin-bottom: 25px;")= page.encrypt_message || '请输入密码查看'
      div(style="display: flex; justify-content: center; gap: 8px; flex-wrap: wrap;")
        input#lock-input(type="text" placeholder="输入密码..." style="padding: 10px 14px; border: 2px solid #e5e1db; border-radius: 8px; background: #fff; color: #1a1a1a; font-size: 1em; width: 160px; outline: none;" lang="zh-CN")
        button#lock-btn(style="padding: 10px 20px; background: #c44536; color: #fff; border: none; border-radius: 8px; cursor: pointer; font-size: 1em;") 进入
      p#lock-err(style="color: #c44536; margin-top: 12px; display: none; font-size: 0.85em;")= page.encrypt_wrong || '❌ 密码错误'

  script.
    (function() {
      var password = '!{page.password}';
      var overlay = document.getElementById('novel-lock-overlay');
      var btn = document.getElementById('lock-btn');
      var input = document.getElementById('lock-input');
      var error = document.getElementById('lock-err');

      function unlock() {
        if (input.value.trim() === password) {
          overlay.style.display = 'none';
        } else {
          error.style.display = 'block';
          input.value = '';
          input.focus();
        }
      }

      btn.addEventListener('click', unlock);
      input.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') unlock();
      });
      input.focus();
    })();
