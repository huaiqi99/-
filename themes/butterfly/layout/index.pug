extends includes/layout.pug

block content
  // Hero 区域 - 打字机开场
  .hero-section
    .hero-content
      h1.hero-title
        span#typewriter
      p.hero-subtitle#typewriter-sub
    .hero-scroll
      span ↓ 向下滚动

  // 小说作品合集
  .novel-collection
    .novel-collection-grid
      // 我在地府打工那些年
      a.novel-collection-card(href=url_for('/novel/'))
        img.novel-collection-cover(src=url_for('/images/difu-cover.jpg') alt='我在地府打工那些年')
        .novel-collection-info
          .novel-collection-name 我在地府打工那些年
          .novel-collection-tags
            span.tag BL
            span.tag 仙侠
            span.tag 原创
          .novel-collection-desc 一场跨越阴阳两界的禁忌之恋，当死神爱上凡人，规则便不再重要。
          .novel-collection-meta 作者：淮子生生 | 121章 | 约64万字
      
      // 这破游戏NPC太能打了
      a.novel-collection-card(href=url_for('/novel2/'))
        img.novel-collection-cover(src=url_for('/images/npc-banner.jpg') alt='这破游戏NPC太能打了')
        .novel-collection-info
          .novel-collection-name 这破游戏NPC太能打了
          .novel-collection-tags
            span.tag BL
            span.tag 游戏
            span.tag 穿越
          .novel-collection-desc 穿越进游戏世界，发现NPC不仅有了自我意识，还强得离谱。
          .novel-collection-meta 作者：淮子生生 | 117章 | 约49万字
      
      // 九州风云录
      a.novel-collection-card(href=url_for('/novel3/'))
        img.novel-collection-cover(src=url_for('/images/jiuzhou-banner.jpg') alt='九州风云录')
        .novel-collection-info
          .novel-collection-name 九州风云录
          .novel-collection-tags
            span.tag GB
            span.tag 仙侠
            span.tag 轻喜剧
          .novel-collection-desc 天宫第一闲人乐游神的追爱日常，三千岁的他能否等来属于自己的春天？
          .novel-collection-meta 作者：淮子生生 | 13章 | 约6万字
      
      // 北境玫瑰（程行歌版）
      a.novel-collection-card(href=url_for('/novel4/'))
        img.novel-collection-cover(src=url_for('/images/beijing2-banner.jpg') alt='北境玫瑰（程行歌版）')
        .novel-collection-info
          .novel-collection-name 北境玫瑰（程行歌版）
          .novel-collection-tags
            span.tag BL
            span.tag 奇幻
            span.tag 原创
          .novel-collection-desc 准神候选人黎昭，从时衍天宫逃难至北境，被Alpha指挥官按在墙上操。
          .novel-collection-meta 作者：程行歌 | 12章 | 约5万字
      
      // 皇叔何出此言
      a.novel-collection-card(href=url_for('/novel5/'))
        img.novel-collection-cover(src=url_for('/images/huangshu-banner.jpg') alt='皇叔何出此言')
        .novel-collection-info
          .novel-collection-name 皇叔何出此言
          .novel-collection-tags
            span.tag BL
            span.tag 古风
            span.tag 短篇
          .novel-collection-desc 栾方棋与林淮的前世今生，两百多岁的他主动提出要做，究竟是何居心？
          .novel-collection-meta 作者：程行歌 | 1章 | 约9万字

  // 打字机效果脚本
  script.
    (function() {
      var titleText = '墨境小说';
      var subtitleText = '用文字构筑世界，让故事在指尖流转';
      var titleEl = document.getElementById('typewriter');
      var subtitleEl = document.getElementById('typewriter-sub');
      var titleIndex = 0;
      var subtitleIndex = 0;

      function typeTitle() {
        if (titleIndex < titleText.length) {
          titleEl.textContent += titleText.charAt(titleIndex);
          titleIndex++;
          setTimeout(typeTitle, 200);
        } else {
          setTimeout(typeSubtitle, 500);
        }
      }

      function typeSubtitle() {
        if (subtitleIndex < subtitleText.length) {
          subtitleEl.textContent += subtitleText.charAt(subtitleIndex);
          subtitleIndex++;
          setTimeout(typeSubtitle, 80);
        }
      }

      // 页面加载后开始
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          setTimeout(typeTitle, 300);
        });
      } else {
        setTimeout(typeTitle, 300);
      }
    })();

  // 滚动淡入效果脚本
  script.
    (function() {
      function fadeInOnScroll() {
        var elements = document.querySelectorAll('.novel-collection-card');
        elements.forEach(function(el) {
          var rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight - 50) {
            el.classList.add('fade-in-visible');
          }
        });
      }

      window.addEventListener('scroll', fadeInOnScroll);
      window.addEventListener('load', fadeInOnScroll);
      fadeInOnScroll();
    })();
