extends includes/layout.pug

block content
  // 小说作品合集
  .novel-collection
    h2.novel-collection-title 作品合集
    p.novel-collection-subtitle 用文字构筑另一个世界
    .novel-collection-grid
      // 我在地府打工那些年
      a.novel-collection-card(href=url_for('/novel/'))
        img.novel-collection-cover(src=url_for('/-/images/difu-cover.jpg') alt='我在地府打工那些年')
        .novel-collection-info
          .novel-collection-name 我在地府打工那些年
          .novel-collection-tags
            span.tag BL
            span.tag 仙侠
            span.tag 原创
          .novel-collection-desc 一场跨越阴阳两界的禁忌之恋，当死神爱上凡人，规则便不再重要。
          .novel-collection-meta 作者：淮子生生 | 121章 | 约64万字

      // 这破游戏NPC太能打了
      a.novel-collection-card(href=url_for('/novel2/'))
        img.novel-collection-cover(src=url_for('/-/images/npc-banner.jpg') alt='这破游戏NPC太能打了')
        .novel-collection-info
          .novel-collection-name 这破游戏NPC太能打了
          .novel-collection-tags
            span.tag BL
            span.tag 游戏
            span.tag 穿越
          .novel-collection-desc 穿越进游戏世界，发现NPC不仅有了自我意识，还强得离谱。
          .novel-collection-meta 作者：淮子生生 | 117章 | 约49万字

      // 九州风云录
      a.novel-collection-card(href=url_for('/novel3/'))
        img.novel-collection-cover(src=url_for('/-/images/jiuzhou-banner.jpg') alt='九州风云录')
        .novel-collection-info
          .novel-collection-name 九州风云录
          .novel-collection-tags
            span.tag GB
            span.tag 仙侠
            span.tag 轻喜剧
          .novel-collection-desc 天宫第一闲人乐游神的追爱日常，三千岁的他能否等来属于自己的春天？
          .novel-collection-meta 作者：淮子生生 | 13章 | 约6万字

      // 北境玫瑰（程行歌版）
      a.novel-collection-card(href=url_for('/novel4/'))
        img.novel-collection-cover(src=url_for('/-/images/beijing2-banner.jpg') alt='北境玫瑰（程行歌版）')
        .novel-collection-info
          .novel-collection-name 北境玫瑰（程行歌版）
          .novel-collection-tags
            span.tag BL
            span.tag 奇幻
            span.tag 原创
          .novel-collection-desc 准神候选人黎昭，从时衍天宫逃难至北境，被Alpha指挥官按在墙上操。
          .novel-collection-meta 作者：程行歌 | 12章 | 约5万字

      // 皇叔何出此言
      a.novel-collection-card(href=url_for('/novel5/'))
        img.novel-collection-cover(src=url_for('/-/images/huangshu-banner.jpg') alt='皇叔何出此言')
        .novel-collection-info
          .novel-collection-name 皇叔何出此言
          .novel-collection-tags
            span.tag BL
            span.tag 古风
            span.tag 短篇
          .novel-collection-desc 栾方棋与林淮的前世今生，两百多岁的他主动提出要做，究竟是何居心？
          .novel-collection-meta 作者：程行歌 | 1章 | 约9万字

      // 还没有名字
      a.novel-collection-card(href=url_for('/novel6/'))
        img.novel-collection-cover(src=url_for('/-/images/豆包.png') alt='还没有名字')
        .novel-collection-info
          .novel-collection-name 还没有名字
          .novel-collection-tags
            span.tag BL
            span.tag 原创
          .novel-collection-desc 还没想好。等未来。也许。
          .novel-collection-meta 作者：淮子生生 | 很多章 | 不知道多少字

      // 小短文合集
      a.novel-collection-card(href=url_for('/novel7/'))
        img.novel-collection-cover(src=url_for('/-/images/fangqi.jpg') alt='小短文合集')
        .novel-collection-info
          .novel-collection-name 小短文合集
          .novel-collection-tags
            span.tag 同人
            span.tag 原神
          .novel-collection-desc 这是当年写大学的时候在lofter上写的原神同人文
          .novel-collection-meta 作者：淮子生生 | 9章 | 约23万字

  // 分页导航
  script.
    document.addEventListener('DOMContentLoaded', function() {
      // ===== 配置区：想改每页几本就改这个数字 =====
      var PER_PAGE = 4;
      // =========================================

      var cards = document.querySelectorAll('.novel-collection-card');
      var grid = document.querySelector('.novel-collection-grid');
      var container = document.querySelector('.novel-collection');

      if (!container || !grid || cards.length <= PER_PAGE) return;

      var totalPages = Math.ceil(cards.length / PER_PAGE);
      var currentPage = 1;

      function showPage(page) {
        if (page < 1) page = 1;
        if (page > totalPages) page = totalPages;
        currentPage = page;

        cards.forEach(function(c, i) {
          if (i >= (page - 1) * PER_PAGE && i < page * PER_PAGE) {
            c.style.display = '';
          } else {
            c.style.display = 'none';
          }
        });

        var btns = document.querySelectorAll('.pg-btn');
        btns.forEach(function(b) {
          var p = parseInt(b.getAttribute('data-p'));
          if (p === page) {
            b.style.background = '#c44536';
            b.style.color = '#fff';
            b.style.borderColor = '#c44536';
            b.style.transform = 'scale(1.05)';
          } else {
            b.style.background = 'var(--card-bg, #fff)';
            b.style.color = 'var(--font-color, #333)';
            b.style.borderColor = 'var(--card-border, #e5e1db)';
            b.style.transform = 'scale(1)';
          }
        });

        var prevBtn = document.querySelector('.pg-prev');
        var nextBtn = document.querySelector('.pg-next');
        if (prevBtn) {
          prevBtn.style.opacity = page === 1 ? '0.4' : '1';
          prevBtn.style.pointerEvents = page === 1 ? 'none' : 'auto';
        }
        if (nextBtn) {
          nextBtn.style.opacity = page === totalPages ? '0.4' : '1';
          nextBtn.style.pointerEvents = page === totalPages ? 'none' : 'auto';
        }

        grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      var pagination = document.createElement('div');
      pagination.className = 'pagination-nav';
      pagination.style.cssText = [
        'display: flex',
        'justify-content: center',
        'align-items: center',
        'gap: 8px',
        'margin-top: 30px',
        'padding: 20px 0',
        'flex-wrap: wrap'
      ].join(';');

      var prev = document.createElement('button');
      prev.className = 'pg-prev';
      prev.innerHTML = '‹ 上一页';
      prev.style.cssText = [
        'height: 38px',
        'padding: 0 16px',
        'border: 1px solid var(--card-border, #e5e1db)',
        'background: var(--card-bg, #fff)',
        'color: var(--font-color, #333)',
        'border-radius: 8px',
        'cursor: pointer',
        'font-size: 14px',
        'font-weight: 500',
        'transition: all 0.2s ease',
        'font-family: inherit'
      ].join(';');
      prev.onmouseover = function() {
        if (currentPage !== 1) this.style.background = 'rgba(196, 69, 54, 0.08)';
      };
      prev.onmouseout = function() {
        if (currentPage !== 1) this.style.background = 'var(--card-bg, #fff)';
      };
      prev.onclick = function() { showPage(currentPage - 1); };
      pagination.appendChild(prev);

      for (var i = 1; i <= totalPages; i++) {
        (function(p) {
          var btn = document.createElement('button');
          btn.className = 'pg-btn';
          btn.setAttribute('data-p', p);
          btn.textContent = p;
          btn.style.cssText = [
            'min-width: 38px',
            'height: 38px',
            'padding: 0 12px',
            'border: 1px solid var(--card-border, #e5e1db)',
            'background: var(--card-bg, #fff)',
            'color: var(--font-color, #333)',
            'border-radius: 8px',
            'cursor: pointer',
            'font-size: 14px',
            'font-weight: 500',
            'transition: all 0.2s ease',
            'font-family: inherit'
          ].join(';');
          btn.onmouseover = function() {
            if (p !== currentPage) this.style.background = 'rgba(196, 69, 54, 0.08)';
          };
          btn.onmouseout = function() {
            if (p !== currentPage) this.style.background = 'var(--card-bg, #fff)';
          };
          btn.onclick = function() { showPage(p); };
          pagination.appendChild(btn);
        })(i);
      }

      var next = document.createElement('button');
      next.className = 'pg-next';
      next.innerHTML = '下一页 ›';
      next.style.cssText = [
        'height: 38px',
        'padding: 0 16px',
        'border: 1px solid var(--card-border, #e5e1db)',
        'background: var(--card-bg, #fff)',
        'color: var(--font-color, #333)',
        'border-radius: 8px',
        'cursor: pointer',
        'font-size: 14px',
        'font-weight: 500',
        'transition: all 0.2s ease',
        'font-family: inherit'
      ].join(';');
      next.onmouseover = function() {
        if (currentPage !== totalPages) this.style.background = 'rgba(196, 69, 54, 0.08)';
      };
      next.onmouseout = function() {
        if (currentPage !== totalPages) this.style.background = 'var(--card-bg, #fff)';
      };
      next.onclick = function() { showPage(currentPage + 1); };
      pagination.appendChild(next);

      container.appendChild(pagination);
      showPage(1);
    });