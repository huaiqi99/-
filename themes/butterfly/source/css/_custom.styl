// ============================
// 小说博客自定义样式
// ============================

// --- 章节导航 ---
.novel-chapter-nav
  margin: 30px 0
  padding: 20px
  background: var(--card-bg)
  border-radius: 12px
  border: 1px solid var(--card-border)

.novel-nav-title
  text-align: center
  font-size: 0.9em
  color: var(--font-color)
  opacity: 0.6
  margin-bottom: 15px
  letter-spacing: 2px

.novel-nav-buttons
  display: flex
  gap: 12px
  justify-content: space-between

.novel-nav-btn
  display: flex
  align-items: center
  gap: 10px
  padding: 12px 16px
  background: var(--btn-bg)
  border-radius: 8px
  text-decoration: none
  color: var(--font-color)
  transition: all 0.3s
  flex: 1
  max-width: 48%

  &:hover
    background: #c44536
    color: #fff
    transform: translateY(-2px)
    box-shadow: 0 4px 12px rgba(196, 69, 54, 0.3)

    .novel-nav-label
      color: rgba(255,255,255,0.8)

.novel-nav-next
  justify-content: flex-end
  text-align: right

.novel-nav-info
  display: flex
  flex-direction: column
  gap: 2px
  min-width: 0

.novel-nav-label
  font-size: 0.75em
  color: var(--font-color)
  opacity: 0.5

.novel-nav-chapter
  font-size: 0.85em
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

.novel-nav-disabled
  opacity: 0.4
  cursor: not-allowed
  pointer-events: none

// --- 首页作品合集 ---
.novel-collection
  padding: 40px 20px
  max-width: 1200px
  margin: 0 auto

.novel-collection-title
  text-align: center
  font-size: 1.8em
  font-weight: bold
  margin-bottom: 10px
  color: var(--font-color)

.novel-collection-subtitle
  text-align: center
  font-size: 0.9em
  color: var(--font-color)
  opacity: 0.6
  margin-bottom: 40px

.novel-collection-grid
  display: grid
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr))
  gap: 24px

.novel-collection-card
  display: block
  background: var(--card-bg)
  border-radius: 12px
  overflow: hidden
  text-decoration: none
  color: var(--font-color)
  border: 1px solid var(--card-border)
  transition: all 0.3s
  opacity: 1                    // 修复：原来为0导致卡片不可见
  transform: translateY(0)      // 修复：原来为30px导致卡片下移

  &:hover
    transform: translateY(-4px) scale(1.02)
    box-shadow: 0 12px 32px rgba(0,0,0,0.2)

  &:active
    transform: translateY(-2px) scale(1.01)

  // 滚动淡入动画（JS添加 fade-in-visible 类时触发）
  &.fade-in-visible
    opacity: 1
    transform: translateY(0)

.novel-collection-cover
  width: 100%
  height: 180px
  object-fit: cover
  display: block

.novel-collection-info
  padding: 16px

.novel-collection-name
  font-size: 1.15em
  font-weight: bold
  margin-bottom: 8px
  color: var(--font-color)

.novel-collection-tags
  display: flex
  gap: 6px
  margin-bottom: 8px
  flex-wrap: wrap

  .tag
    font-size: 0.75em
    padding: 3px 10px
    background: #c44536
    color: #fff
    border-radius: 12px
    font-weight: 500

.novel-collection-desc
  font-size: 0.85em
  color: var(--font-color)
  opacity: 0.7
  line-height: 1.5
  margin-bottom: 10px
  display: -webkit-box
  -webkit-line-clamp: 2
  -webkit-box-orient: vertical
  overflow: hidden

.novel-collection-meta
  font-size: 0.8em
  color: var(--font-color)
  opacity: 0.6

// 字体大小控制
.font-size-control
  display: flex
  align-items: center
  justify-content: center
  gap: 8px
  margin: 15px 0
  padding: 10px
  background: var(--card-bg)
  border-radius: 8px
  border: 1px solid var(--card-border)

.font-label
  font-size: 0.85em
  color: var(--font-color)
  opacity: 0.7

.font-btn
  width: 36px
  height: 36px
  border: 1px solid var(--card-border)
  background: var(--btn-bg)
  color: var(--font-color)
  border-radius: 6px
  cursor: pointer
  font-weight: bold
  font-family: 'Noto Serif SC', serif
  transition: all 0.2s

  &:hover
    background: #c44536
    color: #fff
    border-color: #c44536

// --- Hero 全屏背景区域 ---
// 用于首页顶部全屏背景图（配合 lixi.png）
.hero-fullscreen
  position: relative
  width: 100%
  height: 100vh
  min-height: 600px
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  overflow: hidden

  &::before
    content: ''
    position: absolute
    top: 0
    left: 0
    right: 0
    bottom: 0
    background: url('/-/images/lixi.png') center/cover no-repeat
    z-index: 0

  &::after
    content: ''
    position: absolute
    top: 0
    left: 0
    right: 0
    bottom: 0
    background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.5) 100%)
    z-index: 1

.hero-content
  position: relative
  z-index: 2
  text-align: center
  padding: 40px 20px

.hero-title
  font-size: 4em
  font-weight: bold
  color: #f7f5f0
  margin-bottom: 20px
  font-family: 'Noto Serif SC', serif
  letter-spacing: 8px
  text-shadow: 0 2px 20px rgba(0,0,0,0.5)

  @media (max-width: 768px)
    font-size: 2.5em
    letter-spacing: 4px

.hero-subtitle
  font-size: 1.1em
  color: rgba(255,255,255,0.85)
  font-family: 'Noto Serif SC', serif
  letter-spacing: 2px
  text-shadow: 0 1px 10px rgba(0,0,0,0.5)

  @media (max-width: 768px)
    font-size: 0.9em

.hero-scroll-down
  position: absolute
  bottom: 40px
  left: 50%
  transform: translateX(-50%)
  z-index: 2
  color: rgba(255,255,255,0.7)
  font-size: 0.85em
  animation: bounce 2s infinite
  cursor: pointer
  text-align: center

  i
    display: block
    font-size: 2em
    margin-top: 5px

@keyframes bounce
  0%, 20%, 50%, 80%, 100%
    transform: translateX(-50%) translateY(0)
  40%
    transform: translateX(-50%) translateY(-10px)
  60%
    transform: translateX(-50%) translateY(-5px)

// --- 首页 Hero 区域 ---
// 当前使用的左右分栏样式（配合现有的 header/index.pug）
#site-info
  display: flex
  align-items: center
  justify-content: center
  gap: 60px
  max-width: 1000px
  margin: 0 auto
  padding: 0 40px

  @media (max-width: 768px)
    flex-direction: column
    gap: 20px
    padding: 0 20px

.hero-left
  flex: 0 0 auto
  max-width: 350px

  @media (max-width: 768px)
    max-width: 200px

.hero-character
  width: 100%
  height: auto
  border-radius: 12px
  box-shadow: 0 10px 40px rgba(0,0,0,0.3)
  animation: fadeInLeft 1s ease

  @media (max-width: 768px)
    max-height: 250px
    object-fit: contain

@keyframes fadeInLeft
  from
    opacity: 0
    transform: translateX(-30px)
  to
    opacity: 1
    transform: translateX(0)

.hero-right
  text-align: left

  @media (max-width: 768px)
    text-align: center

#site-title
  font-size: 3.5em
  font-family: 'Noto Serif SC', serif
  letter-spacing: 6px
  margin-bottom: 15px

  @media (max-width: 768px)
    font-size: 2.2em
    letter-spacing: 3px

#site-subtitle
  font-size: 1em
  color: #8a8580
  font-family: 'Noto Serif SC', serif
  letter-spacing: 2px
  min-height: 1.5em
