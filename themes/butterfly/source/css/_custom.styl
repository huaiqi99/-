// ============================
// 小说博客自定义样式
// ============================

// --- 章节导航 ---
.novel-chapter-nav
  margin: 30px 0
  padding: 20px
  background: var(--card-bg)
  border-radius: 12px
  border: 1px solid var(--card-border)

.novel-nav-title
  text-align: center
  font-size: 0.9em
  color: var(--font-color)
  opacity: 0.6
  margin-bottom: 15px
  letter-spacing: 2px

.novel-nav-buttons
  display: flex
  gap: 12px
  justify-content: space-between

.novel-nav-btn
  display: flex
  align-items: center
  gap: 10px
  padding: 12px 16px
  background: var(--btn-bg)
  border-radius: 8px
  text-decoration: none
  color: var(--font-color)
  transition: all 0.3s
  flex: 1
  max-width: 48%

  &:hover
    background: #c44536
    color: #fff
    transform: translateY(-2px)
    box-shadow: 0 4px 12px rgba(196, 69, 54, 0.3)

    .novel-nav-label
      color: rgba(255,255,255,0.8)

.novel-nav-next
  justify-content: flex-end
  text-align: right

.novel-nav-info
  display: flex
  flex-direction: column
  gap: 2px
  min-width: 0

.novel-nav-label
  font-size: 0.75em
  color: var(--font-color)
  opacity: 0.5

.novel-nav-chapter
  font-size: 0.85em
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

.novel-nav-disabled
  opacity: 0.4
  cursor: not-allowed
  pointer-events: none

// --- 首页作品合集 ---
.novel-collection
  padding: 40px 20px
  max-width: 1200px
  margin: 0 auto

.novel-collection-title
  text-align: center
  font-size: 1.8em
  font-weight: bold
  margin-bottom: 10px
  color: var(--font-color)

.novel-collection-subtitle
  text-align: center
  font-size: 0.9em
  color: var(--font-color)
  opacity: 0.6
  margin-bottom: 40px

.novel-collection-grid
  display: grid
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr))
  gap: 24px

.novel-collection-card
  display: block
  background: var(--card-bg)
  border-radius: 12px
  overflow: hidden
  text-decoration: none
  color: var(--font-color)
  border: 1px solid var(--card-border)
  transition: all 0.3s
  opacity: 1
  transform: translateY(0)

  &:hover
    transform: translateY(-4px) scale(1.02)
    box-shadow: 0 12px 32px rgba(0,0,0,0.2)

  &:active
    transform: translateY(-2px) scale(1.01)

.novel-collection-cover
  width: 100%
  height: 180px
  object-fit: cover
  display: block

.novel-collection-info
  padding: 16px

.novel-collection-name
  font-size: 1.15em
  font-weight: bold
  margin-bottom: 8px
  color: var(--font-color)

.novel-collection-tags
  display: flex
  gap: 6px
  margin-bottom: 8px
  flex-wrap: wrap

  .tag
    font-size: 0.75em
    padding: 3px 10px
    background: #c44536
    color: #fff
    border-radius: 12px
    font-weight: 500

.novel-collection-desc
  font-size: 0.85em
  color: var(--font-color)
  opacity: 0.7
  line-height: 1.5
  margin-bottom: 10px
  display: -webkit-box
  -webkit-line-clamp: 2
  -webkit-box-orient: vertical
  overflow: hidden

.novel-collection-meta
  font-size: 0.8em
  color: var(--font-color)
  opacity: 0.6

// 字体大小控制
.font-size-control
  display: flex
  align-items: center
  justify-content: center
  gap: 8px
  margin: 15px 0
  padding: 10px
  background: var(--card-bg)
  border-radius: 8px
  border: 1px solid var(--card-border)

.font-label
  font-size: 0.85em
  color: var(--font-color)
  opacity: 0.7

.font-btn
  width: 36px
  height: 36px
  border: 1px solid var(--card-border)
  background: var(--btn-bg)
  color: var(--font-color)
  border-radius: 6px
  cursor: pointer
  font-weight: bold
  font-family: 'Noto Serif SC', serif
  transition: all 0.2s

  &:hover
    background: #c44536
    color: #fff
    border-color: #c44536

// --- 首页全屏背景图标题居中 ---
#page-header.full_page
  #site-info
    position: absolute
    top: 50%
    left: 50%
    transform: translate(-50%, -50%)

    #site-title
      font-size: 4em
      color: #fff
      text-shadow: 0 2px 20px rgba(0,0,0,0.6)
      letter-spacing: 8px

    #site-subtitle
      color: rgba(255,255,255,0.9)
      text-shadow: 0 1px 10px rgba(0,0,0,0.5)
      letter-spacing: 2px

// ============================
// 世界观设定集样式
// ============================

// --- 世界观首页卡片网格 ---
.world-header
  text-align: center
  padding: 40px 20px
  margin-bottom: 20px

  h1
    font-size: 2.2em
    color: var(--font-color)
    margin-bottom: 10px

  p
    font-size: 1em
    color: var(--font-color)
    opacity: 0.6

.world-grid
  display: grid
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr))
  gap: 24px
  max-width: 1200px
  margin: 0 auto
  padding: 0 20px 40px

.world-card
  display: block
  background: var(--card-bg)
  border-radius: 12px
  overflow: hidden
  text-decoration: none
  color: var(--font-color)
  border: 1px solid var(--card-border)
  transition: all 0.3s

  &:hover
    transform: translateY(-4px)
    box-shadow: 0 8px 24px rgba(0,0,0,0.12)

.world-card-cover
  width: 100%
  height: 180px
  object-fit: cover
  display: block

.world-card-info
  padding: 16px

.world-card-name
  font-size: 1.2em
  font-weight: bold
  margin-bottom: 8px
  color: var(--font-color)

.world-card-tags
  display: flex
  gap: 6px
  margin-bottom: 8px
  flex-wrap: wrap

  .tag
    font-size: 0.75em
    padding: 3px 10px
    background: #c44536
    color: #fff
    border-radius: 12px
    font-weight: 500

.world-card-desc
  font-size: 0.85em
  color: var(--font-color)
  opacity: 0.7
  line-height: 1.5
  display: -webkit-box
  -webkit-line-clamp: 2
  -webkit-box-orient: vertical
  overflow: hidden

// --- 世界观详情页 ---
.world-detail-header
  text-align: center
  padding: 30px 20px
  margin-bottom: 20px

  .world-back
    display: inline-block
    margin-bottom: 15px
    color: #c44536
    text-decoration: none
    font-size: 0.9em

    &:hover
      text-decoration: underline

  h1
    font-size: 2em
    color: var(--font-color)
    margin-bottom: 8px

  .world-subtitle
    font-size: 1em
    color: var(--font-color)
    opacity: 0.6

// 三界架构三栏布局
.world-triad
  display: grid
  grid-template-columns: repeat(3, 1fr)
  gap: 20px
  margin: 20px 0

  @media (max-width: 768px)
    grid-template-columns: 1fr

.world-triad-item
  padding: 20px
  background: var(--card-bg)
  border-radius: 10px
  border: 1px solid var(--card-border)

  h3
    font-size: 1.2em
    color: #c44536
    margin-bottom: 10px
    text-align: center

  p
    font-size: 0.9em
    line-height: 1.7
    color: var(--font-color)
    opacity: 0.85

// 折叠面板样式
.world-accordion
  margin: 15px 0

  details
    margin-bottom: 10px
    background: var(--card-bg)
    border-radius: 10px
    border: 1px solid var(--card-border)
    overflow: hidden

    summary
      padding: 15px 20px
      font-size: 1.1em
      font-weight: bold
      color: var(--font-color)
      cursor: pointer
      transition: all 0.3s
      list-style: none
      position: relative
      padding-left: 45px

      &:before
        content: '▶'
        position: absolute
        left: 18px
        top: 50%
        transform: translateY(-50%)
        font-size: 0.7em
        color: #c44536
        transition: transform 0.3s

      &:hover
        background: rgba(196, 69, 54, 0.05)

    &[open]
      summary
        border-bottom: 1px solid var(--card-border)

        &:before
          transform: translateY(-50%) rotate(90deg)

.world-accordion-content
  padding: 20px

  h4
    font-size: 1.05em
    color: #c44536
    margin: 15px 0 8px

    &:first-child
      margin-top: 0

  p
    font-size: 0.9em
    line-height: 1.8
    color: var(--font-color)
    opacity: 0.85
    margin-bottom: 10px

  ul
    padding-left: 20px
    margin: 10px 0

    li
      font-size: 0.9em
      line-height: 1.8
      color: var(--font-color)
      opacity: 0.85
      margin-bottom: 5px

  blockquote
    border-left: 3px solid #c44536
    padding: 10px 15px
    margin: 15px 0
    background: rgba(196, 69, 54, 0.05)
    border-radius: 0 8px 8px 0
    font-style: italic
    color: var(--font-color)
    opacity: 0.8

// 角色列表
.world-character-list
  display: grid
  gap: 15px

.world-character-item
  padding: 15px
  background: rgba(196, 69, 54, 0.03)
  border-radius: 8px
  border-left: 3px solid #c44536

  h4
    font-size: 1em
    color: #c44536
    margin-bottom: 5px

  p
    font-size: 0.88em
    line-height: 1.7
    color: var(--font-color)
    opacity: 0.8
    margin: 0

// 表格样式
.world-table
  width: 100%
  border-collapse: collapse
  margin: 15px 0
  font-size: 0.9em

  th, td
    padding: 12px 15px
    text-align: left
    border-bottom: 1px solid var(--card-border)

  th
    background: rgba(196, 69, 54, 0.08)
    color: #c44536
    font-weight: bold

  td
    color: var(--font-color)
    opacity: 0.85

  tr:hover
    background: rgba(196, 69, 54, 0.03)

// 世界观区块
.world-section
  max-width: 900px
  margin: 0 auto 30px
  padding: 0 20px

  h2
    font-size: 1.6em
    color: var(--font-color)
    margin: 30px 0 15px
    padding-bottom: 10px
    border-bottom: 2px solid #c44536

  > p
    font-size: 0.95em
    line-height: 1.8
    color: var(--font-color)
    opacity: 0.85
    margin-bottom: 12px
